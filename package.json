{
  "name": "codex-feishu-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu message bridge for controlling local Codex sessions without using a secondary AI model.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:feishu": "tsx src/feishuWs.ts",
    "feishu": "node dist/feishuWs.js"
  },
  "devDependencies": {
    "@openai/codex": "^0.142.4",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.68.0"
  }
}
