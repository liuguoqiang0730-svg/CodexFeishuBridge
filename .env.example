HOST=127.0.0.1
PORT=8787

# Codex local state. Empty means C:\Users\<you>\.codex.
CODEX_HOME=

# Recommended after npm install:
# CODEX_BIN=E:\Codex-AI-Coding\CodexFeishuBridge\node_modules\@openai\codex\bin\codex.js
CODEX_BIN=codex

# auto = try app-server first, then fallback to cli
# app-server = only app-server
# cli = only codex exec resume
CODEX_SEND_MODE=auto

DEFAULT_MODEL=gpt-5.5
DEFAULT_EFFORT=medium

# /ask timeout before Feishu receives an error message. Default: 60000.
FEISHU_ASK_TIMEOUT_MS=60000

# Fallback folder scan only. Codex Desktop local state is still the source of truth.
CODEX_PROJECTS_ROOT=E:\Codex-AI-Coding

# Feishu long-connection mode.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Allowlist userId/openId/chatId, comma separated.
FEISHU_ALLOWED_USER_IDS=local-dev

# Only needed for HTTP callback mode, not required for long-connection mode.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
CODEX_APP_SERVER_URL=
